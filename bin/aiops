#!/usr/bin/env sh
set -eu

usage() {
  cat <<'EOF'
aiops - AI Agent Ops project helper

Usage:
  aiops seed [--adapter codex|claude|both] [--mode link|copy] [--target DIR] [--core DIR] [--force]
  aiops doctor [--target DIR] [--strict]
  aiops bootstrap-guide [--target DIR]
  aiops validate task FILE
  aiops version [--core DIR]
  aiops update [--core DIR] [--check]
  aiops release-check [--core DIR] [--strict]
  aiops help

Defaults:
  adapter: codex
  mode: link
  target: current directory
  core: AIOPS_CORE_HOME, or ai-agent-ops directory that contains this bin/aiops

Examples:
  aiops seed --adapter codex
  aiops seed --adapter claude
  aiops seed --adapter both --mode copy
  aiops doctor
  aiops validate task .ai_project/tasks/active/T-YYYYMMDD-001.md
  aiops bootstrap-guide
  aiops update --check
  aiops release-check --strict
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

info() {
  printf '%s\n' "$*"
}

same_file_content() {
  [ -f "$1" ] && [ -f "$2" ] && cmp -s "$1" "$2"
}

check_required_file() {
  file="$1"
  label="$2"
  if [ -f "$file" ]; then
    info "ok: $label"
  else
    info "missing: $label"
    return 1
  fi
}

check_required_dir() {
  dir="$1"
  label="$2"
  if [ -d "$dir" ]; then
    info "ok: $label"
  else
    info "missing: $label"
    return 1
  fi
}

detect_ai_project_mode() {
  project_dir="$1"
  operating_model="$project_dir/operating_model.md"

  if [ ! -f "$operating_model" ]; then
    printf '%s\n' "unknown"
    return 0
  fi

  if grep -q 'bootstrap_mode.*fast_track' "$operating_model"; then
    printf '%s\n' "fast_track"
  else
    printf '%s\n' "guided_full"
  fi
}

task_field_value() {
  file="$1"
  field="$2"
  awk -F': *' -v field="$field" '$1 == field { print $2; exit }' "$file"
}

markdown_table_value() {
  file="$1"
  key="$2"
  awk -F'|' -v key="$key" '
    NF >= 3 {
      left=$2
      value=$3
      gsub(/^[ \t]+|[ \t]+$/, "", left)
      gsub(/^[ \t]+|[ \t]+$/, "", value)
      gsub(/^`|`$/, "", value)
      if (left == key) {
        print value
        exit
      }
    }
  ' "$file"
}

task_has_field() {
  file="$1"
  field="$2"
  grep -q "^$field:" "$file"
}

validate_task_file() {
  task="$1"
  failed=0

  [ -f "$task" ] || {
    info "missing: $task"
    return 1
  }

  info "AI Ops task validate"
  info "task: $task"

  for field in id status workflow target_role required_capabilities; do
    if task_has_field "$task" "$field"; then
      info "ok: $field"
    else
      info "missing: $field"
      failed=1
    fi
  done

  status="$(task_field_value "$task" "status")"
  case "$status" in
    approved|in_progress)
      for field in allowed_paths source_of_truth report_to; do
        if task_has_field "$task" "$field"; then
          info "ok: $field"
        else
          info "missing: $field required for status $status"
          failed=1
        fi
      done
      ;;
    verification_ready|verification_in_progress|verification_passed)
      if task_has_field "$task" "qa_to"; then
        info "ok: qa_to"
      else
        info "missing: qa_to required for status $status"
        failed=1
      fi
      ;;
    blocked)
      for field in blocker next_decision; do
        if task_has_field "$task" "$field"; then
          info "ok: $field"
        else
          info "missing: $field required for status blocked"
          failed=1
        fi
      done
      ;;
    "")
      ;;
    *)
      info "note: no status-specific checks for $status"
      ;;
  esac

  [ "$failed" -eq 0 ] || return 1
  info "ok: task metadata"
}

print_markdown_section_list() {
  file="$1"
  heading="$2"
  [ -f "$file" ] || return 0
  awk -v heading="$heading" '
    $0 == heading { in_section=1; next }
    in_section && /^## / { exit }
    in_section && /^[0-9]+[.]/ { print "      " $0 }
    in_section && /^- / { print "      " $0 }
  ' "$file"
}

print_agent_registry_rows() {
  file="$1"
  [ -f "$file" ] || return 0
  awk -F'|' '
    substr($0, 1, 1) == "|" && $0 !~ /---/ && $0 !~ /^\|[ \t]*(담당|Agent)[ \t]*\|/ && $0 ~ /enabled/ {
      left=$2
      role=$5
      if (role == "") {
        role=$4
      }
      gsub(/^[ \t]+|[ \t]+$/, "", left)
      gsub(/^[ \t]+|[ \t]+$/, "", role)
      if (left != "" && role != "") {
        print "      - " left " / " role
      }
    }
  ' "$file"
}

script_dir() {
  source="$0"
  while [ -L "$source" ]; do
    dir="$(cd "$(dirname "$source")" && pwd)"
    link="$(readlink "$source")"
    case "$link" in
      /*) source="$link" ;;
      *) source="$dir/$link" ;;
    esac
  done
  cd "$(dirname "$source")" && pwd
}

default_core_dir() {
  if [ "${AIOPS_CORE_HOME:-}" ]; then
    cd "$AIOPS_CORE_HOME" && pwd
    return
  fi
  cd "$(script_dir)/.." && pwd
}

abs_path() {
  if [ -d "$1" ]; then
    cd "$1" && pwd
  else
    case "$1" in
      /*) printf '%s\n' "$1" ;;
      *) printf '%s\n' "$(pwd)/$1" ;;
    esac
  fi
}

require_core() {
  core="$1"
  [ -d "$core" ] || die "core directory not found: $core"
  [ -f "$core/core/constitution.md" ] || die "invalid core: missing core/constitution.md"
  [ -f "$core/bootstrap/bootstrap_runbook.md" ] || die "invalid core: missing bootstrap/bootstrap_runbook.md"
  [ -f "$core/templates/tool_adapters/codex/AGENTS.md" ] || die "invalid core: missing codex adapter"
}

copy_core() {
  core="$1"
  target_ai="$2"
  mkdir "$target_ai"
  (
    cd "$core"
    tar \
      --exclude '.git' \
      --exclude '.DS_Store' \
      --exclude '.ai_project' \
      -cf - .
  ) | (
    cd "$target_ai"
    tar -xf -
  )
}

seed_adapter() {
  core="$1"
  target="$2"
  adapter="$3"
  force="$4"

  case "$adapter" in
    codex)
      src="$core/templates/tool_adapters/codex/AGENTS.md"
      dest="$target/AGENTS.md"
      ;;
    claude)
      src="$core/templates/tool_adapters/claude/CLAUDE.md"
      dest="$target/CLAUDE.md"
      ;;
    *)
      die "unknown adapter: $adapter"
      ;;
  esac

  [ -f "$src" ] || die "adapter template not found: $src"

  if [ -e "$dest" ] && [ "$force" != "yes" ]; then
    info "skip: $(basename "$dest") already exists"
    return 0
  fi

  cp "$src" "$dest"
  info "created: $dest"
}

cmd_seed() {
  adapter="codex"
  mode="link"
  target="$(pwd)"
  core="$(default_core_dir)"
  force="no"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --adapter)
        shift
        [ "$#" -gt 0 ] || die "--adapter requires a value"
        adapter="$1"
        ;;
      --mode)
        shift
        [ "$#" -gt 0 ] || die "--mode requires a value"
        mode="$1"
        ;;
      --target)
        shift
        [ "$#" -gt 0 ] || die "--target requires a value"
        target="$1"
        ;;
      --core)
        shift
        [ "$#" -gt 0 ] || die "--core requires a value"
        core="$1"
        ;;
      --force)
        force="yes"
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown seed option: $1"
        ;;
    esac
    shift
  done

  target="$(abs_path "$target")"
  core="$(abs_path "$core")"
  require_core "$core"

  [ -d "$target" ] || die "target directory not found: $target"
  [ "$target" != "$core" ] || die "target cannot be the ai-agent-ops core directory"

  target_ai="$target/.ai"

  if [ -e "$target_ai" ] || [ -L "$target_ai" ]; then
    if [ "$force" = "yes" ]; then
      rm -rf "$target_ai"
    else
      info "skip: .ai already exists"
    fi
  fi

  if [ ! -e "$target_ai" ] && [ ! -L "$target_ai" ]; then
    case "$mode" in
      link)
        ln -s "$core" "$target_ai"
        info "created: $target_ai -> $core"
        ;;
      copy)
        copy_core "$core" "$target_ai"
        info "created: $target_ai"
        ;;
      *)
        die "unknown mode: $mode"
        ;;
    esac
  fi

  case "$adapter" in
    codex)
      seed_adapter "$core" "$target" codex "$force"
      ;;
    claude)
      seed_adapter "$core" "$target" claude "$force"
      ;;
    both)
      seed_adapter "$core" "$target" codex "$force"
      seed_adapter "$core" "$target" claude "$force"
      ;;
    *)
      die "unknown adapter: $adapter"
      ;;
  esac

  info ""
  info "AI Ops seed complete."
  info "Next: open an agent session in $target and say:"
  info "  AI Ops bootstrap 시작해줘."
}

cmd_doctor() {
  target="$(pwd)"
  strict="no"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --target)
        shift
        [ "$#" -gt 0 ] || die "--target requires a value"
        target="$1"
        ;;
      --strict)
        strict="yes"
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown doctor option: $1"
        ;;
    esac
    shift
  done

  target="$(abs_path "$target")"
  ai="$target/.ai"
  failed=0
  warnings=0

  info "AI Ops doctor"
  info "target: $target"
  info "strict: $strict"

  if [ -L "$ai" ]; then
    link_target="$(readlink "$ai")"
    info "ok: .ai symlink -> $link_target"
  elif [ -d "$ai" ]; then
    info "ok: .ai directory"
    info "warn: .ai is a writable project-local directory; symlink mode is recommended for vendor core"
    warnings=$((warnings + 1))
  else
    info "missing: .ai"
    failed=1
  fi

  for required in \
    "$ai/core/constitution.md" \
    "$ai/bootstrap/bootstrap_runbook.md" \
    "$ai/bootstrap/install_runbook.md" \
    "$ai/models/role_model.md" \
    "$ai/runtime/workflow.md"
  do
    check_required_file "$required" "${required#$target/}" || failed=1
  done

  if [ -f "$target/AGENTS.md" ]; then
    info "ok: AGENTS.md"
    if [ -f "$ai/templates/tool_adapters/codex/AGENTS.md" ]; then
      if same_file_content "$target/AGENTS.md" "$ai/templates/tool_adapters/codex/AGENTS.md"; then
        info "ok: AGENTS.md matches codex adapter template"
      else
        info "warn: AGENTS.md differs from codex adapter template"
        warnings=$((warnings + 1))
      fi
    fi
  else
    info "note: AGENTS.md missing"
  fi

  if [ -f "$target/CLAUDE.md" ]; then
    info "ok: CLAUDE.md"
    if [ -f "$ai/templates/tool_adapters/claude/CLAUDE.md" ]; then
      if same_file_content "$target/CLAUDE.md" "$ai/templates/tool_adapters/claude/CLAUDE.md"; then
        info "ok: CLAUDE.md matches claude adapter template"
      else
        info "warn: CLAUDE.md differs from claude adapter template"
        warnings=$((warnings + 1))
      fi
    fi
  else
    info "note: CLAUDE.md missing"
  fi

  if [ -d "$target/.ai_project" ]; then
    info "ok: .ai_project"
    ai_project_mode="$(detect_ai_project_mode "$target/.ai_project")"
    info "mode: .ai_project $ai_project_mode"
    operating_model="$target/.ai_project/operating_model.md"

    for required in \
      "$target/.ai_project/operating_model.md" \
      "$target/.ai_project/agent_registry.md" \
      "$target/.ai_project/current_context.md" \
      "$target/.ai_project/source_of_truth.md" \
      "$target/.ai_project/task_board.md" \
      "$target/.ai_project/ops_decisions.md" \
      "$target/.ai_project/ops_issues.md" \
      "$target/.ai_project/tasks"
    do
      if [ -d "$required" ]; then
        check_required_dir "$required" "${required#$target/}" || failed=1
      else
        check_required_file "$required" "${required#$target/}" || failed=1
      fi
    done

    if [ "$ai_project_mode" = "fast_track" ]; then
      for optional in \
        "$target/.ai_project/branch_pr_strategy.md" \
        "$target/.ai_project/workflow_overrides.md" \
        "$target/.ai_project/ops_migration_plan.md"
      do
        if [ -e "$optional" ]; then
          info "ok: optional ${optional#$target/}"
        else
          info "note: optional for fast_track missing ${optional#$target/}"
        fi
      done
    else
      for required in \
        "$target/.ai_project/branch_pr_strategy.md" \
        "$target/.ai_project/workflow_overrides.md" \
        "$target/.ai_project/ops_migration_plan.md"
      do
        check_required_file "$required" "${required#$target/}" || failed=1
      done
    fi

    for task_dir in "$target/.ai_project/tasks/active" "$target/.ai_project/tasks/backlog" "$target/.ai_project/tasks/archive"; do
      if [ -d "$task_dir" ]; then
        info "ok: ${task_dir#$target/}"
      else
        info "warn: missing ${task_dir#$target/}"
        warnings=$((warnings + 1))
      fi
    done

    if [ -d "$target/.ai_project/tasks" ]; then
      task_warning_file="${TMPDIR:-/tmp}/aiops-doctor-task-warnings.$$"
      : > "$task_warning_file"
      find "$target/.ai_project/tasks" -type f -name '*.md' | while IFS= read -r task; do
        if ! grep -q '^status:' "$task"; then
          printf 'warn: task missing status: %s\n' "${task#$target/}"
          printf '1\n' >> "$task_warning_file"
        fi
        if ! grep -q '^target_role:' "$task"; then
          printf 'warn: task missing target_role: %s\n' "${task#$target/}"
          printf '1\n' >> "$task_warning_file"
        fi
        if grep -q '^status: verification_ready' "$task"; then
          qa_to="$(awk -F': ' '/^qa_to:/{print $2; exit}' "$task")"
          if [ -z "$qa_to" ]; then
            printf 'warn: verification_ready task missing qa_to: %s\n' "${task#$target/}"
            printf '1\n' >> "$task_warning_file"
          elif [ -f "$target/$qa_to" ]; then
            printf 'ok: qa report exists for %s\n' "${task#$target/}"
          else
            printf 'note: qa report pending for %s -> %s\n' "${task#$target/}" "$qa_to"
          fi
        fi
      done
      if [ -s "$task_warning_file" ]; then
        task_warnings="$(wc -l < "$task_warning_file" | tr -d ' ')"
        warnings=$((warnings + task_warnings))
      fi
      rm -f "$task_warning_file"
    fi

    if [ -f "$ai/VERSION" ] && [ -f "$operating_model" ]; then
      current_core_version="$(cat "$ai/VERSION")"
      recorded_core_version="$(task_field_value "$operating_model" "core_version")"
      if [ -z "$recorded_core_version" ]; then
        recorded_core_version="$(markdown_table_value "$operating_model" "core_version")"
      fi

      case "$recorded_core_version" in
        ""|"{{CORE_VERSION}}")
          info "note: .ai_project core_version not recorded"
          ;;
        "$current_core_version")
          info "ok: .ai_project core_version matches $current_core_version"
          ;;
        *)
          info "warn: .ai_project core_version $recorded_core_version differs from current core $current_core_version"
          warnings=$((warnings + 1))
          ;;
      esac
    fi
  else
    info "note: .ai_project missing; run bootstrap when ready"
  fi

  if [ -f "$ai/VERSION" ]; then
    info "version: $(cat "$ai/VERSION")"
  fi

  if [ "$strict" = "yes" ] && [ "$warnings" -gt 0 ]; then
    failed=1
  fi

  info "warnings: $warnings"
  [ "$failed" -eq 0 ] || exit 1
}

cmd_validate() {
  subject="${1:-}"
  [ "$#" -gt 0 ] || die "validate requires a subject: task"
  shift

  case "$subject" in
    task)
      [ "$#" -eq 1 ] || die "validate task requires exactly one FILE"
      validate_task_file "$1"
      ;;
    *)
      die "unknown validate subject: $subject"
      ;;
  esac
}

cmd_version() {
  core="$(default_core_dir)"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --core)
        shift
        [ "$#" -gt 0 ] || die "--core requires a value"
        core="$1"
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown version option: $1"
        ;;
    esac
    shift
  done

  core="$(abs_path "$core")"
  require_core "$core"
  if [ -f "$core/VERSION" ]; then
    cat "$core/VERSION"
  else
    die "VERSION not found"
  fi
}

cmd_update() {
  core="$(default_core_dir)"
  check_only="no"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --core)
        shift
        [ "$#" -gt 0 ] || die "--core requires a value"
        core="$1"
        ;;
      --check)
        check_only="yes"
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown update option: $1"
        ;;
    esac
    shift
  done

  core="$(abs_path "$core")"
  require_core "$core"

  current_version="unknown"
  if [ -f "$core/VERSION" ]; then
    current_version="$(cat "$core/VERSION")"
  fi

  info "AI Ops update"
  info "core: $core"
  info "current version: $current_version"

  if [ -d "$core/.git" ]; then
    branch="$(git -C "$core" rev-parse --abbrev-ref HEAD 2>/dev/null || printf 'unknown')"
    info "install method: git checkout"
    info "branch: $branch"

    if [ "$check_only" = "yes" ]; then
      info ""
      info "No files changed."
      info "To update this git-based core:"
      info "  aiops update --core \"$core\""
      return 0
    fi

    if ! git -C "$core" diff --quiet || ! git -C "$core" diff --cached --quiet; then
      die "core has local changes; commit, stash, or resolve them before update"
    fi

    git -C "$core" pull --ff-only

    new_version="$current_version"
    if [ -f "$core/VERSION" ]; then
      new_version="$(cat "$core/VERSION")"
    fi

    info ""
    info "AI Ops update complete."
    info "previous version: $current_version"
    info "current version: $new_version"
    info "Next: run doctor in target projects:"
    info "  aiops doctor --strict"
    return 0
  fi

  info "install method: packaged or copied core"
  info ""
  if [ "$check_only" = "yes" ]; then
    info "No files changed."
  fi
  info "This core is not a git checkout, so aiops will not modify it directly."
  info "If installed with Homebrew in the future, update with:"
  info "  brew upgrade ai-agent-ops"
  info "If copied into a project, reseed from an updated core after reviewing migration impact."
}

cmd_release_check() {
  core="$(default_core_dir)"
  strict="no"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --core)
        shift
        [ "$#" -gt 0 ] || die "--core requires a value"
        core="$1"
        ;;
      --strict)
        strict="yes"
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown release-check option: $1"
        ;;
    esac
    shift
  done

  core="$(abs_path "$core")"
  require_core "$core"

  failed=0
  warnings=0
  version="unknown"
  if [ -f "$core/VERSION" ]; then
    version="$(cat "$core/VERSION")"
  fi

  info "AI Ops release check"
  info "core: $core"
  info "version: $version"
  info "strict: $strict"

  case "$version" in
    *[!0-9.]*|*.*.*.*|.*|*.)
      info "warn: VERSION should be semantic numeric form like 0.6.1"
      warnings=$((warnings + 1))
      ;;
    *.*.*)
      info "ok: VERSION format"
      ;;
    *)
      info "warn: VERSION should be semantic numeric form like 0.6.1"
      warnings=$((warnings + 1))
      ;;
  esac

  for required in \
    "$core/README.md" \
    "$core/QUICKSTART.md" \
    "$core/CHANGELOG.md" \
    "$core/docs/installation.md" \
    "$core/docs/distribution.md" \
    "$core/bin/aiops" \
    "$core/Formula/ai-agent-ops.rb" \
    "$core/core/constitution.md" \
    "$core/policies/versioning_policy.md" \
    "$core/runtime/workflow.md" \
    "$core/runtime/task_queue.md" \
    "$core/templates/tool_adapters/codex/AGENTS.md" \
    "$core/templates/tool_adapters/claude/CLAUDE.md"
  do
    check_required_file "$required" "${required#$core/}" || failed=1
  done

  if [ -f "$core/CHANGELOG.md" ]; then
    if grep -q "^## $version " "$core/CHANGELOG.md"; then
      info "ok: CHANGELOG has version section"
    else
      info "warn: CHANGELOG missing section for $version"
      warnings=$((warnings + 1))
    fi
  fi

  formula="$core/Formula/ai-agent-ops.rb"
  if [ -f "$formula" ]; then
    if grep -q "refs/tags/v$version.tar.gz" "$formula" || grep -q "tag:[[:space:]]*\"v$version\"" "$formula"; then
      info "ok: Formula version reference matches VERSION"
    else
      info "warn: Formula version reference does not match VERSION v$version"
      warnings=$((warnings + 1))
    fi

    if grep -q 'REPLACE_WITH_RELEASE_SHA256' "$formula"; then
      info "warn: Formula sha256 placeholder must be replaced before Homebrew release"
      warnings=$((warnings + 1))
    elif grep -q "refs/tags/v$version.tar.gz" "$formula"; then
      if grep -Eq 'sha256 "[0-9a-f]{64}"' "$formula"; then
        info "ok: Formula sha256 format"
      else
        info "warn: Formula sha256 is missing or invalid"
        warnings=$((warnings + 1))
      fi
    elif grep -q "tag:[[:space:]]*\"v$version\"" "$formula"; then
      if grep -Eq 'revision:[[:space:]]*"[0-9a-f]{40}"' "$formula"; then
        info "ok: Formula git revision format"
      else
        info "warn: Formula git revision is missing or invalid"
        warnings=$((warnings + 1))
      fi
    else
      info "warn: Formula source format is not recognized"
      warnings=$((warnings + 1))
    fi

    if command -v ruby >/dev/null 2>&1; then
      if ruby -c "$formula" >/dev/null 2>&1; then
        info "ok: Formula Ruby syntax"
      else
        info "warn: Formula Ruby syntax failed"
        warnings=$((warnings + 1))
      fi
    else
      info "note: ruby not available; Formula syntax not checked"
    fi
  fi

  if [ -f "$core/LICENSE" ] || [ -f "$core/LICENSE.md" ]; then
    info "ok: LICENSE"
  else
    info "warn: LICENSE missing; choose a license before public Homebrew release"
    warnings=$((warnings + 1))
  fi

  if [ -d "$core/.git" ]; then
    if git -C "$core" diff --quiet && git -C "$core" diff --cached --quiet; then
      info "ok: git working tree clean"
    else
      info "warn: git working tree has uncommitted changes"
      warnings=$((warnings + 1))
    fi
  fi

  if [ "$strict" = "yes" ] && [ "$warnings" -gt 0 ]; then
    failed=1
  fi

  info "warnings: $warnings"
  [ "$failed" -eq 0 ] || exit 1
}

cmd_bootstrap_guide() {
  target="$(pwd)"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --target)
        shift
        [ "$#" -gt 0 ] || die "--target requires a value"
        target="$1"
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown bootstrap-guide option: $1"
        ;;
    esac
    shift
  done

  target="$(abs_path "$target")"
  ai="$target/.ai"

  info "AI Ops bootstrap guide"
  info "target: $target"
  info ""

  if [ -L "$ai" ] || [ -d "$ai" ]; then
    info "ok: .ai exists"
  else
    info "missing: .ai"
    info ""
    info "먼저 seed를 실행하세요:"
    info "  aiops seed --target \"$target\" --adapter codex"
    info ""
    info "Codex와 Claude를 함께 쓸 경우:"
    info "  aiops seed --target \"$target\" --adapter both"
    return 0
  fi

  if [ -f "$target/AGENTS.md" ]; then
    info "ok: AGENTS.md"
  else
    info "note: AGENTS.md missing"
  fi

  if [ -f "$target/CLAUDE.md" ]; then
    info "ok: CLAUDE.md"
  else
    info "note: CLAUDE.md missing"
  fi

  if [ -d "$target/.ai_project" ]; then
    info "ok: .ai_project exists"
    info ""
    info "현재 프로젝트는 AI Ops 운영 구성이 이미 완료된 상태입니다."
    info ""
    info "활성 Agent / Role 후보:"
    if [ -f "$target/.ai_project/agent_registry.md" ]; then
      print_agent_registry_rows "$target/.ai_project/agent_registry.md"
    else
      info "      - agent_registry.md 없음"
    fi
    info ""
    info "현재 초점:"
    if [ -f "$target/.ai_project/current_context.md" ]; then
      print_markdown_section_list "$target/.ai_project/current_context.md" "## 다음 초점"
    elif [ -f "$target/.ai_project/task_board.md" ]; then
      print_markdown_section_list "$target/.ai_project/task_board.md" "## Current Focus"
    else
      info "      - current_context.md 없음"
    fi
    info ""
    info "다음 단계:"
    info "  - 운영 상태를 점검하려면:"
    info "      aiops doctor --target \"$target\" --strict"
    info "  - 첫 Agent 세션을 시작하려면:"
    info "      너는 PM Agent / Lead Role이야. 현재 운영 상태와 다음 Task 후보를 정리해줘."
    info "  - 운영모델 자체를 점검하려면:"
    info "      너는 AI Ops Agent / Ops Governance Role이야. .ai_project 운영 구성을 점검하고 개선 필요사항만 보고해줘."
    info "  - 운영 구성을 다시 검토해야 할 때만:"
    info "      AI Ops bootstrap 재검토해줘."
  else
    info "note: .ai_project missing"
    info ""
    info "새 운영 구성을 시작하려면 Agent 세션에서 말하세요:"
    info "  AI Ops bootstrap 시작해줘."
    info ""
    info "Bootstrap 진행 방식:"
    info "  1. 빠른 시작"
    info "     - 처음 쓰는 사용자나 작은 프로젝트에 적합합니다."
    info "     - 쉬운 질문 몇 개와 안전 기본값으로 시작합니다."
    info "  2. 세부 설정"
    info "     - Team, Role, Workflow, Ownership, Board, Branch/PR을 직접 비교하며 정합니다."
    info ""
    info "원칙:"
    info "  - Discovery Phase에서는 파일을 수정하지 않습니다."
    info "  - .ai_project 생성/수정은 Operating Model Draft 승인 후에만 진행합니다."
  fi
}

main() {
  cmd="${1:-help}"
  if [ "$#" -gt 0 ]; then
    shift
  fi

  case "$cmd" in
    seed) cmd_seed "$@" ;;
    doctor) cmd_doctor "$@" ;;
    bootstrap-guide) cmd_bootstrap_guide "$@" ;;
    validate) cmd_validate "$@" ;;
    version) cmd_version "$@" ;;
    update) cmd_update "$@" ;;
    release-check) cmd_release_check "$@" ;;
    help|-h|--help) usage ;;
    *) die "unknown command: $cmd" ;;
  esac
}

main "$@"
